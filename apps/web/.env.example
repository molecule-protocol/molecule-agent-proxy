# ===================================
# Molecule Agent Proxy — apps/web/.env.local
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# ===================================

# --- Arc network ---
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER_BASE=https://testnet.arcscan.app

# --- Contract addresses (filled after deploy from packages/contracts) ---
NEXT_PUBLIC_IDENTITY_REGISTRY=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VALIDATION_REGISTRY=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MOLECULE_VAULT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_REVOCATION_REGISTRY=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_USDC_ADDRESS=0x0000000000000000000000000000000000000000

# --- Public branding ---
NEXT_PUBLIC_PROXY_BASE_URL=https://proxy.moleculeprotocol.io
NEXT_PUBLIC_DASHBOARD_BASE_URL=https://moleculeprotocol.io

# --- Server-only secrets (NEVER expose to client) ---
# OpenRouter key (in production this comes from per-user encrypted storage; for
# the hackathon demo we ship a single key the demo user provides at onboarding)
OPENROUTER_API_KEY=sk-or-v1-REPLACE-ME

# Symmetric key used to encrypt/decrypt user-supplied OpenRouter keys at rest.
# Generate with: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
MAP_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS

# Iron-session cookie secret (≥32 chars).
# Generate with: node -e "console.log(crypto.randomBytes(32).toString('base64'))"
SESSION_COOKIE_SECRET=REPLACE_WITH_32_PLUS_CHARS_BASE64

# Wallet that pays gas for on-chain charge TXs (the proxy submits TXs via this wallet
# and reimburses itself out of the protocol fee). Use a fresh wallet for the hackathon.
PROXY_RELAYER_PRIVATE_KEY=0xREPLACE_WITH_PRIVATE_KEY

# --- Vercel KV (Redis) for nonce + cap counters ---
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# --- Reclaim Protocol ---
RECLAIM_APP_ID=
RECLAIM_APP_SECRET=
RECLAIM_PROVIDER_ID_KYC=
