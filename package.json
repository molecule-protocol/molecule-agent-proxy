{
  "name": "molecule-agent-proxy",
  "version": "0.1.0",
  "private": true,
  "description": "Molecule Agent Proxy (MAP) - Identity-gated, key-free API access for AI agents. Per-call nano-payments in USDC on Arc.",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter @molecule/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "contracts:build": "pnpm --filter @molecule/contracts build",
    "contracts:test": "pnpm --filter @molecule/contracts test",
    "contracts:deploy": "pnpm --filter @molecule/contracts deploy:arc"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
