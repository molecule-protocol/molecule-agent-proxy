# Foundry deploy + test env
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# Deployer wallet (the address that will own deployed contracts)
DEPLOYER_PRIVATE_KEY=0xREPLACE_WITH_PRIVATE_KEY

# USDC ERC-20 system contract on Arc testnet (6 decimals on the ERC-20 interface).
# Source: https://docs.arc.network/arc/references/contract-addresses
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Optional: protocol fee per call, in USDC base units (6 decimals). 500 = $0.0005.
PER_CALL_FEE=500

# Where per-call protocol fees flow (can be deployer for hackathon)
PROTOCOL_TREASURY=0x7483DDe29C04C6f3B53c847d13445748854b04cD
